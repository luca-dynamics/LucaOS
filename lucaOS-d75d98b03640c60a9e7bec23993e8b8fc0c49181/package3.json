{
  "name": "luca-os-prime",
  "description": "L.U.C.A (Large Universal Control Agent) — A cinematic-grade personal AI operating system for technical operators.",
  "private": false,
  "license": "MIT",
  "version": "1.0.0",
  "type": "module",
  "main": "platforms/electron/main.cjs",
  "scripts": {
    "dev": "vite",
    "start": "vite",
    "build": "tsc && vite build",
    "lint": "eslint . --ext ts,tsx --report-unused-disable-directives --max-warnings 0",
    "preview": "vite preview",
    "server": "node server.js",
    "cortex": "./cortex/python/venv/bin/python3 cortex/python/cortex.py",
    "cortex:build": "sh ops/scripts/build-cortex.sh",
    "start:all": "concurrently -k -p \"[{name}]\" -n \"UI,CORE,BRAIN\" -c \"cyan,magenta,yellow\" \"npm run dev\" \"npm run server\" \"npm run cortex\"",
    "cleanup": "./ops/scripts/cleanup.sh",
    "restore": "node ops/scripts/restore.js",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "type-check": "tsc --noEmit",
    "safety-check": "npm run lint && npm run type-check && node ops/scripts/verify_integrity.cjs",
    "mobile:init": "npm run build && node ops/scripts/build-mobile.js init",
    "mobile:sync": "npm run build && node ops/scripts/build-mobile.js sync",
    "mobile:android": "npm run mobile:sync && node ops/scripts/build-mobile.js open android",
    "mobile:ios": "npm run mobile:sync && node ops/scripts/build-mobile.js open ios",
    "mobile:build:android": "npm run mobile:sync && cd android && ./gradlew assembleRelease",
    "mobile:build:ios": "npm run mobile:sync && cd ios && xcodebuild -workspace App.xcworkspace -scheme App -configuration Release archive",
    "electron:dev": "concurrently -k \"npm run dev\" \"wait-on tcp:3000 && unset ELECTRON_RUN_AS_NODE && electron .\"",
    "electron:full": "concurrently -k -p \"[{name}]\" -n \"VITE,ELECTRON\" -c \"cyan,blue\" \"npm run dev\" \"wait-on tcp:3000 && unset ELECTRON_RUN_AS_NODE && electron .\"",
    "phoenix": "node ops/phoenix/supervisor.cjs",
    "postinstall": "electron-rebuild -v 40.7.0"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.71.2",
    "@capacitor-community/barcode-scanner": "^4.0.1",
    "@capacitor/app-launcher": "^6.0.4",
    "@emotion/is-prop-valid": "^1.4.0",
    "@google/genai": "*",
    "@google/generative-ai": "^0.24.1",
    "@mediapipe/tasks-genai": "^0.10.26",
    "@mediapipe/tasks-vision": "^0.10.22-rc.20250304",
    "@mlc-ai/web-llm": "^0.2.80",
    "@modelcontextprotocol/sdk": "^1.23.0",
    "@monaco-editor/react": "^4.6.0",
    "@octokit/rest": "^22.0.1",
    "@phosphor-icons/react": "^2.1.10",
    "@picovoice/porcupine-web": "^3.0.3",
    "@picovoice/web-voice-processor": "^4.0.9",
    "@react-three/drei": "^9.122.0",
    "@react-three/fiber": "^8.18.0",
    "@remixicon/react": "^4.9.0",
    "@ricky0123/vad-web": "^0.0.30",
    "@shiguredo/rnnoise-wasm": "^2025.1.5",
    "@solar-icons/react": "^1.1.0",
    "@tensorflow-models/speech-commands": "^0.5.4",
    "@tensorflow/tfjs": "^4.22.0",
    "@tensorflow/tfjs-backend-cpu": "^4.22.0",
    "@tensorflow/tfjs-backend-webgl": "^4.22.0",
    "@tensorflow/tfjs-core": "^4.22.0",
    "@tensorflow/tfjs-data": "^4.22.0",
    "@tensorflow/tfjs-layers": "^4.22.0",
    "@types/dagre": "^0.7.54",
    "@types/react-syntax-highlighter": "^15.5.13",
    "@xyflow/react": "^12.10.1",
    "@zxing/browser": "^0.1.5",
    "@zxing/library": "^0.21.3",
    "active-win": "^8.2.1",
    "better-sqlite3": "^12.4.5",
    "bonjour-service": "^1.2.1",
    "ccxt": "^4.5.27",
    "cheerio": "^1.0.0-rc.12",
    "chokidar": "^5.0.0",
    "chromium-bidi": "^12.0.1",
    "cors": "^2.8.5",
    "crypto-js": "^4.2.0",
    "dagre": "^0.8.5",
    "dotenv": "^17.2.3",
    "ethers": "^6.16.0",
    "eventsource": "^4.1.0",
    "express": "^4.18.2",
    "framer-motion": "^12.23.26",
    "google-auth-library": "^10.5.0",
    "googleapis": "^168.0.0",
    "https-proxy-agent": "^7.0.2",
    "hyperliquid": "^1.7.7",
    "idb": "^8.0.3",
    "input": "^1.0.1",
    "js-yaml": "^4.1.1",
    "lighter-node-client": "^1.0.0",
    "lightweight-charts": "^5.0.9",
    "localtunnel": "^1.8.3",
    "lucide-react": "^1.7.0",
    "mqtt": "^5.14.1",
    "msgpack-lite": "^0.1.26",
    "multer": "^2.0.2",
    "node-cron": "^4.2.1",
    "openai": "^6.10.0",
    "playwright": "^1.58.2",
    "qrcode": "^1.5.4",
    "quartz": "^0.0.1",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "react-force-graph-3d": "^1.29.0",
    "react-json-view": "^1.21.3",
    "react-markdown": "^10.1.0",
    "react-syntax-highlighter": "^16.1.0",
    "recharts": "^2.12.2",
    "remark-gfm": "^4.0.1",
    "robotjs": "^0.7.0",
    "socket.io": "^4.8.1",
    "socket.io-client": "^4.8.3",
    "technicalindicators": "^3.1.0",
    "telegram": "^2.26.22",
    "three": "^0.181.0",
    "tweetnacl": "^1.0.3",
    "tweetnacl-util": "^0.15.1",
    "uuid": "^13.0.0",
    "wake_on_lan": "^1.0.0",
    "whatsapp-web.js": "^1.34.6",
    "ws": "^8.16.0",
    "xlsx": "^0.18.5",
    "xml2js": "^0.6.2",
    "zod": "^3.22.4"
  },
  "devDependencies": {
    "@capacitor/android": "^6.2.1",
    "@capacitor/cli": "^8.2.0",
    "@capacitor/core": "^6.2.1",
    "@capacitor/ios": "^6.2.1",
    "@electron/rebuild": "^4.0.1",
    "@types/crypto-js": "^4.2.2",
    "@types/node": "^25.0.10",
    "@types/qrcode": "^1.5.6",
    "@types/react": "^18.3.27",
    "@types/react-dom": "^18.3.7",
    "@typescript-eslint/eslint-plugin": "^8.50.1",
    "@typescript-eslint/parser": "^8.50.1",
    "@vitejs/plugin-react": "^4.2.1",
    "@vitest/ui": "^4.0.17",
    "autoprefixer": "^10.4.18",
    "capacitor-zeroconf": "^4.0.0",
    "concurrently": "^8.2.2",
    "electron": "^40.7.0",
    "electron-builder": "^26.8.1",
    "eslint": "^8.57.0",
    "eslint-plugin-react": "^7.37.5",
    "jsdom": "^27.4.0",
    "postcss": "^8.4.35",
    "tailwindcss": "^3.4.1",
    "typescript": "^5.2.2",
    "vite": "^6.2.1",
    "vitest": "^4.0.17",
    "wait-on": "^7.2.0"
  },
  "build": {
    "appId": "com.luca.ai",
    "productName": "Luca OS",
    "mac": {
      "category": "public.app-category.productivity",
      "target": "dmg",
      "extendInfo": {
        "NSLocationWhenInUseUsageDescription": "Luca needs access to location services to scan for nearby Wi-Fi networks and show their real names.",
        "NSLocationAlwaysAndWhenInUseUsageDescription": "Luca needs access to location services to scan for nearby Wi-Fi networks and show their real names."
      }
    },
    "win": {
      "target": "nsis"
    },
    "linux": {
      "target": "AppImage"
    },
    "files": [
      "dist/**/*",
      "platforms/electron/**/*",
      "server.js",
      "package.json",
      "node_modules/**/*"
    ],
    "extraResources": [
      {
        "from": "cortex/python/dist/cortex",
        "to": "bin/cortex"
      }
    ],
    "directories": {
      "buildResources": "assets"
    }
  }
}
