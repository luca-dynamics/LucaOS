{
  "name": "luca-os-landing",
  "version": 2,
  "cleanUrls": true,
  "trailingSlash": false,
  "rewrites": [
    { "source": "/pitch", "destination": "/pitch/index.html" },
    { "source": "/community", "destination": "/community/index.html" },
    { "source": "/resources", "destination": "/resources/index.html" },
    { "source": "/download/(.*)", "destination": "/download/$1.html" },
    { "source": "/legal/(.*)", "destination": "/legal/$1.html" },
    { "source": "/resources/(.*)", "destination": "/resources/$1.html" }
  ]
}
